<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>谢怡童｜AI Resume</title>
  <meta name="description" content="谢怡童的苹果风格 AI 简历页面，适合 GitHub Pages 展示。" />
  <style>
    :root {
      --bg: #000000;
      --bg-soft: #0a0a0a;
      --card: rgba(255,255,255,0.06);
      --card-strong: rgba(255,255,255,0.1);
      --line: rgba(255,255,255,0.12);
      --text: #ffffff;
      --muted: rgba(255,255,255,0.72);
      --muted-2: rgba(255,255,255,0.52);
      --accent: #7dd3fc;
      --shadow: 0 20px 60px rgba(0,0,0,0.45);
      --radius-xl: 32px;
      --radius-lg: 24px;
      --max: 1120px;
    }

    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      margin: 0;
      font-family: -apple-system, BlinkMacSystemFont, "SF Pro Display", "SF Pro Text", "PingFang SC", "Helvetica Neue", Arial, sans-serif;
      color: var(--text);
      background:
        radial-gradient(circle at top, rgba(125,211,252,0.08), transparent 28%),
        linear-gradient(180deg, #050505 0%, #000000 45%, #050505 100%);
      line-height: 1.65;
      overflow-x: hidden;
    }

    a {
      color: #ffffff;
      text-decoration: none;
      transition: opacity .25s ease, transform .25s ease;
    }

    a:hover { opacity: .82; }

    .wrap {
      width: min(calc(100% - 32px), var(--max));
      margin: 0 auto;
    }

    .nav-shell {
      position: sticky;
      top: 0;
      z-index: 50;
      backdrop-filter: saturate(180%) blur(20px);
      background: rgba(10,10,10,0.68);
      border-bottom: 1px solid rgba(255,255,255,0.08);
    }

    .nav {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      padding: 14px 0;
    }

    .brand {
      font-size: 15px;
      font-weight: 600;
      letter-spacing: -0.01em;
    }

    .nav-links {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }

    .nav-links a {
      color: var(--muted);
      font-size: 14px;
      padding: 8px 12px;
      border-radius: 999px;
    }

    .nav-links a:hover,
    .nav-links a.active {
      color: #fff;
      background: rgba(255,255,255,0.08);
    }

    .hero {
      padding: 72px 0 28px;
      text-align: center;
    }

    .hero-eyebrow {
      display: inline-block;
      padding: 8px 14px;
      border-radius: 999px;
      background: rgba(255,255,255,0.06);
      border: 1px solid rgba(255,255,255,0.08);
      color: var(--muted);
      font-size: 13px;
      backdrop-filter: blur(12px);
    }

    .hero h1 {
      font-size: clamp(42px, 8vw, 84px);
      line-height: 1.02;
      letter-spacing: -0.05em;
      margin: 18px 0 14px;
      color: #ffffff;
    }

    .hero p {
      margin: 0 auto;
      max-width: 760px;
      font-size: clamp(18px, 2.4vw, 26px);
      line-height: 1.45;
      color: rgba(255,255,255,0.78);
      letter-spacing: -0.02em;
    }

    .hero-actions {
      margin-top: 28px;
      display: flex;
      justify-content: center;
      flex-wrap: wrap;
      gap: 12px;
    }

    .button {
      padding: 13px 18px;
      border-radius: 999px;
      background: rgba(255,255,255,0.08);
      border: 1px solid rgba(255,255,255,0.1);
      color: #fff;
      font-weight: 500;
      backdrop-filter: blur(14px);
      box-shadow: 0 10px 30px rgba(0,0,0,.18);
    }

    .button.primary {
      background: #ffffff;
      color: #000000;
    }

    .button:hover {
      transform: translateY(-1px);
    }

    .hero-stats {
      margin-top: 34px;
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 14px;
    }

    .glass {
      background: linear-gradient(180deg, rgba(255,255,255,0.08), rgba(255,255,255,0.04));
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: var(--radius-lg);
      backdrop-filter: blur(18px) saturate(160%);
      box-shadow: var(--shadow);
    }

    .stat {
      padding: 22px;
      text-align: left;
      transition: transform .35s ease, border-color .35s ease, background .35s ease;
    }

    .stat:hover,
    .reveal-card:hover,
    .timeline-item:hover,
    .skill-block:hover {
      transform: translateY(-4px);
      border-color: rgba(255,255,255,0.18);
      background: linear-gradient(180deg, rgba(255,255,255,0.12), rgba(255,255,255,0.05));
    }

    .label {
      font-size: 12px;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--muted-2);
      margin-bottom: 8px;
    }

    .value {
      font-size: clamp(22px, 3vw, 32px);
      letter-spacing: -0.04em;
      font-weight: 700;
    }

    section.content-section {
      padding: 18px 0 10px;
    }

    .section-header {
      display: flex;
      justify-content: space-between;
      align-items: end;
      gap: 12px;
      margin-bottom: 16px;
    }

    .section-header h2 {
      margin: 0;
      font-size: clamp(28px, 4vw, 44px);
      letter-spacing: -0.04em;
    }

    .section-header span {
      color: var(--muted-2);
      font-size: 13px;
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }

    .reveal-card {
      padding: 26px;
      transition: transform .4s ease, opacity .6s ease, filter .6s ease;
    }

    .timeline {
      display: grid;
      gap: 16px;
    }

    .timeline-item {
      padding: 24px;
      transition: transform .35s ease, background .35s ease, border-color .35s ease;
    }

    .timeline-top {
      display: flex;
      align-items: start;
      justify-content: space-between;
      gap: 12px;
      margin-bottom: 8px;
      flex-wrap: wrap;
    }

    .timeline-top h3 {
      margin: 0;
      font-size: 22px;
      letter-spacing: -0.02em;
    }

    .time {
      color: var(--muted-2);
      font-size: 14px;
      white-space: nowrap;
    }

    .role {
      color: rgba(255,255,255,0.84);
      font-weight: 600;
      margin-bottom: 10px;
    }

    ul {
      margin: 0;
      padding-left: 18px;
      color: var(--muted);
    }

    li { margin: 8px 0; }

    .two-col {
      display: grid;
      grid-template-columns: 1.08fr .92fr;
      gap: 16px;
    }

    .skill-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0,1fr));
      gap: 14px;
    }

    .skill-block {
      padding: 20px;
      transition: transform .35s ease, background .35s ease, border-color .35s ease;
    }

    .skill-block h3 {
      margin: 0 0 12px;
      font-size: 18px;
      letter-spacing: -0.02em;
    }

    .tags {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }

    .tag {
      padding: 7px 11px;
      border-radius: 999px;
      border: 1px solid rgba(255,255,255,0.08);
      background: rgba(255,255,255,0.05);
      color: #fff;
      font-size: 13px;
    }

    .profile-text {
      font-size: 17px;
      line-height: 1.8;
      color: var(--muted);
      margin: 0;
    }

    .floating-orb {
      position: fixed;
      width: 320px;
      height: 320px;
      border-radius: 50%;
      filter: blur(90px);
      background: rgba(125,211,252,0.08);
      top: 10%;
      right: -100px;
      pointer-events: none;
      z-index: 0;
      animation: floaty 8s ease-in-out infinite;
    }

    @keyframes floaty {
      0%,100% { transform: translateY(0px); }
      50% { transform: translateY(24px); }
    }

    .reveal {
      opacity: 0;
      transform: translateY(24px);
      filter: blur(10px);
    }

    .reveal.visible {
      opacity: 1;
      transform: translateY(0);
      filter: blur(0);
    }

    footer {
      padding: 36px 0 60px;
      text-align: center;
      color: var(--muted-2);
      font-size: 14px;
    }

    @media (max-width: 900px) {
      .hero-stats,
      .two-col,
      .skill-grid {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 640px) {
      .nav { flex-direction: column; align-items: flex-start; }
      .hero { padding-top: 48px; }
      .reveal-card, .timeline-item, .skill-block, .stat { padding: 20px; }
      .section-header { align-items: start; flex-direction: column; }
    }
  </style>
</head>
